{
  "$schema": "http://json-schema.org/schema",
  "id": "QmlComponentSchema",
  "title": "QML Component Options",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Component name"
    },
    "qmlFile": {
      "type": "string",
      "description": "Path to source QML file"
    },
    "path": {
      "type": "string",
      "description": "Destination path"
    }
  },
  "required": ["name", "qmlFile"]
}
