{
  "name": "qml-ng",
  "version": "0.3.0",
  "private": true,
  "description": "QML to Angular Material converter starter",
  "main": "dist/index.js",
  "bin": {
    "qml-ng": "dist/cli.js"
  },
  "files": [
    "dist",
    "collection.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "test": "npm run build && node --test --test-isolation=none test/**/*.test.mjs",
    "validate": "npm run test && node scripts/validate.mjs"
  },
  "dependencies": {
    "@angular-devkit/core": "^20.0.0",
    "@angular-devkit/schematics": "^20.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "typescript": "^5.8.0"
  }
}
